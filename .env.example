# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.
# `scripts/run_phase0.py` loads this via python-dotenv (the `data` extra).

# Root of the mounted corpus volume. Loaders resolve every dataset `metadata`
# path (and the source audio it points to) under this directory.
DAGGER_DATA_ROOT=/mnt/data

# WSJ0-2mix only. WSJ0 has no API key — it is LDC-licensed. Leave BLANK when the
# corpus is already mounted under DAGGER_DATA_ROOT. Set it only to authorize a
# fetch of the licensed data from a private mirror / gated endpoint you control.
DAGGER_WSJ0_ACCESS_KEY=
